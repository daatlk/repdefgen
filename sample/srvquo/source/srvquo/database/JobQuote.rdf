CREATE OR REPLACE VIEW JOB_QUOTE_REP AS
SELECT RESULT_KEY, ROW_NO, PARENT_ROW_NO, ROWVERSION
   ,QUOTATION_NO,WO_NO,WQ_DATE_CREATED,SQ_DATE_CREATED,WQ_CREATED_BY,SQ_USER_CREATED,CUSTOMER_REFERENCE,CUSTOMER_ID,CUSTOMER_ADDRESS,CUSTOMER_NAME,SERVICE_ASSET_TAG,ASSET_DESCRIPTION,SERIAL_NO,SYSTEM_ASSET_ID,QUOTATION_REV,SITE_ADDRESS,CURRENT_SPEND,DETAIL,QUANTITY,PRICE,VALUE
FROM   JOB_QUOTE_RPT t
WHERE EXISTS (SELECT 1 FROM allowed_report a WHERE a.result_key = t.result_key)
WITH   read only;

