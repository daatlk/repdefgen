PROMPT Creating JOB_QUOTE_RPI implementation

CREATE OR REPLACE PACKAGE BODY JOB_QUOTE_RPI IS

   TYPE binds$ IS RECORD (
      quotation_no              VARCHAR2(32000),
      wo_no                     NUMBER,
      quotation_rev             VARCHAR2(32000));

   CURSOR get_job_quote_header (quotation_no_ VARCHAR2, wo_no_ NUMBER) IS
      select  wq.QUOTATION_NO,
              wq.DATE_CREATED WQ_DATE_CREATED,
              sq.DT_CRE SQ_DATE_CREATED,
              wq.CREATED_BY as WQ_CREATED_BY,
              sq.USER_CREATED AS SQ_USER_CREATED,
              sq.CUSTOMER_REFERENCE,
              NVL(wq.wo_no, wq.wo_quo_no) as WO_NO,
              sq.CUSTOMER_ID,
              csa.address as customer_address,
              (customer_info_api.Get_Name(sq.CUSTOMER_ID)) AS customer_name,
              ceq.CF$_QR_CODE as Service_Asset_Tag,
              ceq.MCH_NAME as Asset_Description,
              ceq.SERIAL_NO,
              ceq.OBJECT_NO as System_Asset_ID,
              wq.QUOTATION_REV,
              null as test,
              Service_Quotation_Address_API.Get_Formatted_Address(sq.quotation_no,
                                                                       sq.quotation_rev,
                                                                       'VISIT') as site_address,
              SUM(st.total_cost) as current_spend
       
         from WO_SRV_QUO wq
         LEFT JOIN service_quotation sq
           on wq.quotation_no = sq. quotation_no
         left join (SELECT a.Address, a.Address_Id, a.Customer_Id, t.Def_Address
                      from CUSTOMER_INFO_ADDRESS a
                      LEFT OUTER JOIN CUSTOMER_INFO_ADDRESS_TYPE t
                        ON a.Customer_Id = t.Customer_Id
                       and a.Address_Id = t.Address_Id
                     WHERE t.Def_Address = 'TRUE'
                       AND t.Address_Type_Code = 'Document') csa
           on sq.customer_id = csa.customer_id
         left join EQUIPMENT_OBJECT_UIV_CFV ceq
           on wq.Mch_Code = ceq.Mch_Code
          AND wq.MCH_CODE_CONTRACT = ceq.Contract
        left join SERVICE_QUOTATION_TOTALS_UIV st on sq.quotation_no = st.quotation_no AND sq.quotation_rev = st.quotation_rev 
        where wq.QUOTATION_NO = quotation_no_
          and NVL(wq.wo_no, wq.wo_quo_no) = wo_no_
        GROUP BY
              wq.QUOTATION_NO,
              wq.DATE_CREATED,
              sq.DT_CRE,
              wq.CREATED_BY,
              sq.USER_CREATED,
              sq.CUSTOMER_REFERENCE,
              NVL(wq.wo_no, wq.wo_quo_no),
              sq.CUSTOMER_ID,
              csa.address,
              ceq.CF$_QR_CODE,
              ceq.MCH_NAME,
              ceq.SERIAL_NO,
              ceq.OBJECT_NO,
              wq.QUOTATION_REV,
              Service_Quotation_Address_API.Get_Formatted_Address(
                  sq.quotation_no,
                  sq.quotation_rev,
                  'VISIT'
              );

   CURSOR get_job_quote_detail (quotation_no_ VARCHAR2, quotation_rev_ VARCHAR2, wo_no_ NUMBER) IS
      select wp.CATALOG_DESCRIPTION as detail, wp.PLANNED_QTY as quantity,wp.PRICE_SOURCE_ID as price,wp.SALES_PRICE_CURR as value
      from WO_PLAN_SRV_QUO wp
      where wp.QUOTATION_NO = quotation_no_ and wp.QUOTATION_REV=quotation_rev_ and wp.WO_QUO_NO=wo_no_;

-----------------------------------------------------------------------------
-------------------- RESULT SET METHODS -------------------------------------
-----------------------------------------------------------------------------

--@IgnoreWrongParamOrder
PROCEDURE Add_Result_Row___ (
   result_key$_               IN NUMBER,
   binds$_                    IN binds$,
   rec_job_quote_header_      IN get_job_quote_header%ROWTYPE DEFAULT NULL,
   rec_job_quote_detail_      IN get_job_quote_detail%ROWTYPE DEFAULT NULL,
   row_no$_                   IN OUT NUMBER)
IS
BEGIN
   INSERT INTO JOB_QUOTE_RPT (
      result_key,
      quotation_no,
      wo_no,
      wq_date_created,
      sq_date_created,
      wq_created_by,
      sq_user_created,
      customer_reference,
      customer_id,
      customer_address,
      customer_name,
      service_asset_tag,
      asset_description,
      serial_no,
      system_asset_id,
      quotation_rev,
      site_address,
      current_spend,
      detail,
      quantity,
      price,
      value,
      row_no, parent_row_no)
   VALUES (
      result_key$_,
      nvl(rec_job_quote_header_.quotation_no,
      binds$_.quotation_no),
      nvl(rec_job_quote_header_.wo_no,
      binds$_.wo_no),
      rec_job_quote_header_.wq_date_created,
      rec_job_quote_header_.sq_date_created,
      rec_job_quote_header_.wq_created_by,
      rec_job_quote_header_.sq_user_created,
      rec_job_quote_header_.customer_reference,
      rec_job_quote_header_.customer_id,
      rec_job_quote_header_.customer_address,
      rec_job_quote_header_.customer_name,
      rec_job_quote_header_.service_asset_tag,
      rec_job_quote_header_.asset_description,
      rec_job_quote_header_.serial_no,
      rec_job_quote_header_.system_asset_id,
      rec_job_quote_header_.quotation_rev,
      rec_job_quote_header_.site_address,
      rec_job_quote_header_.current_spend,
      rec_job_quote_detail_.detail,
      rec_job_quote_detail_.quantity,
      rec_job_quote_detail_.price,
      rec_job_quote_detail_.value,
      row_no$_, 0);
   row_no$_ := row_no$_+1;
END Add_Result_Row___;

