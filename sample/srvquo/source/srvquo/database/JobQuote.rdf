-------------------- REPORT EXECUTION ---------------------------------------
-----------------------------------------------------------------------------

PROCEDURE Execute_Report (
   report_attr_    IN VARCHAR2,
   parameter_attr_ IN VARCHAR2 )
IS
   result_key$_              NUMBER;
   row_no$_                  NUMBER := 1;
   binds$_                   binds$;
   xml$_                     CLOB;
   outer_filter_attr$_       VARCHAR2(32000);
   outer_filter_where$_      VARCHAR2(32000);
   inner_filter_attr$_       VARCHAR2(32000);
   inner_filter_where$_      VARCHAR2(32000);
   has_job_quote_header_ BOOLEAN;
   rec_job_quote_header_ get_job_quote_header%ROWTYPE;
   par_job_quote_header_ binds$;
   has_job_quote_detail_ BOOLEAN;
   rec_job_quote_detail_ get_job_quote_detail%ROWTYPE;
   par_job_quote_detail_ binds$;
BEGIN
   General_SYS.Init_Method(lu_name_, 'JOB_QUOTE_RPI', 'Execute_Report');
   result_key$_                 := Client_SYS.Attr_Value_To_Number(Client_SYS.Get_Item_Value('RESULT_KEY', report_attr_));
   binds$_.quotation_no         := Client_SYS.Get_Item_Value('QUOTATION_NO', parameter_attr_); 
   binds$_.wo_no                := Client_SYS.Attr_Value_To_Number(Client_SYS.Get_Item_Value('WO_NO', parameter_attr_));

   Xml_Record_Writer_SYS.Create_Report_Header(xml$_, 'JOB_QUOTE_REP', 'Job Quote');

   has_job_quote_header_ := FALSE;
   par_job_quote_header_ := binds$_;
   Xml_Record_Writer_SYS.Start_Element(xml$_, 'HEADERS1');
   OPEN get_job_quote_header(binds$_.quotation_no, binds$_.wo_no);
   LOOP
      FETCH get_job_quote_header INTO rec_job_quote_header_;
      has_job_quote_header_ := get_job_quote_header%FOUND OR get_job_quote_header%ROWCOUNT > 0;
      EXIT WHEN get_job_quote_header%NOTFOUND;
      Xml_Record_Writer_SYS.Start_Element(xml$_, 'JOB_QUOTE_HEADER');
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'QUOTATION_NO', rec_job_quote_header_.quotation_no);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'WQ_DATE_CREATED', rec_job_quote_header_.wq_date_created);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'SQ_DATE_CREATED', rec_job_quote_header_.sq_date_created);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'WQ_CREATED_BY', rec_job_quote_header_.wq_created_by);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'SQ_USER_CREATED', rec_job_quote_header_.sq_user_created);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CUSTOMER_REFERENCE', rec_job_quote_header_.customer_reference);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'WO_NO', rec_job_quote_header_.wo_no);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CUSTOMER_ID', rec_job_quote_header_.customer_id);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CUSTOMER_ADDRESS', rec_job_quote_header_.customer_address);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CUSTOMER_NAME', rec_job_quote_header_.customer_name);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'SERVICE_ASSET_TAG', rec_job_quote_header_.service_asset_tag);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'ASSET_DESCRIPTION', rec_job_quote_header_.asset_description);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'SERIAL_NO', rec_job_quote_header_.serial_no);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'SYSTEM_ASSET_ID', rec_job_quote_header_.system_asset_id);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'QUOTATION_REV', rec_job_quote_header_.quotation_rev);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'SITE_ADDRESS', rec_job_quote_header_.site_address);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CURRENT_SPEND', rec_job_quote_header_.current_spend);
      has_job_quote_detail_ := FALSE;
      par_job_quote_detail_ := binds$_;
      binds$_.quotation_no := rec_job_quote_header_.quotation_no;
      binds$_.quotation_rev := rec_job_quote_header_.quotation_rev;
      binds$_.wo_no := rec_job_quote_header_.wo_no;
      Xml_Record_Writer_SYS.Start_Element(xml$_, 'DETAILS1');
      OPEN get_job_quote_detail(rec_job_quote_header_.quotation_no, rec_job_quote_header_.quotation_rev, rec_job_quote_header_.wo_no);
      LOOP
         FETCH get_job_quote_detail INTO rec_job_quote_detail_;
         has_job_quote_detail_ := get_job_quote_detail%FOUND OR get_job_quote_detail%ROWCOUNT > 0;
         EXIT WHEN get_job_quote_detail%NOTFOUND;
         Xml_Record_Writer_SYS.Start_Element(xml$_, 'JOB_QUOTE_DETAIL');
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'DETAIL', rec_job_quote_detail_.detail);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'QUANTITY', rec_job_quote_detail_.quantity);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'PRICE', rec_job_quote_detail_.price);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'VALUE', rec_job_quote_detail_.value);
         Xml_Record_Writer_SYS.End_Element(xml$_, 'JOB_QUOTE_DETAIL');
         Add_Result_Row___(result_key$_,
                           binds$_ => binds$_,
                           rec_job_quote_header_ => rec_job_quote_header_,
                           rec_job_quote_detail_ => rec_job_quote_detail_,
                           row_no$_ => row_no$_);
      END LOOP;
      CLOSE get_job_quote_detail;
      Xml_Record_Writer_SYS.End_Element(xml$_, 'DETAILS1');
      binds$_ := par_job_quote_detail_;
      IF NOT has_job_quote_detail_ THEN
         Add_Result_Row___(result_key$_,
                           binds$_ => binds$_,
                           rec_job_quote_header_ => rec_job_quote_header_,
                           row_no$_ => row_no$_);
      END IF;

      Xml_Record_Writer_SYS.End_Element(xml$_, 'JOB_QUOTE_HEADER');
   END LOOP;
   CLOSE get_job_quote_header;
   Xml_Record_Writer_SYS.End_Element(xml$_, 'HEADERS1');
   binds$_ := par_job_quote_header_;
   IF NOT has_job_quote_header_ THEN
      Add_Result_Row___(result_key$_,
                        binds$_ => binds$_,
                        row_no$_ => row_no$_);
   END IF;

   Xml_Record_Writer_SYS.End_Element(xml$_, 'JOB_QUOTE_REP');
   Report_SYS.Finish_Xml_Report('JOB_QUOTE_REP', result_key$_, xml$_);
   EXCEPTION
      WHEN OTHERS THEN
         IF get_job_quote_header%ISOPEN THEN
            CLOSE get_job_quote_header;
         END IF;
         IF get_job_quote_detail%ISOPEN THEN
            CLOSE get_job_quote_detail;
         END IF;
         RAISE;
END Execute_Report;

