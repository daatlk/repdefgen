CREATE OR REPLACE VIEW EXT_SYSTEM_CLEAN_REP AS
SELECT RESULT_KEY, ROW_NO, PARENT_ROW_NO, ROWVERSION
   ,WO_NO,TASK_NO,TASK_SEQ,CUSTOMER_NO,CUSTOMER_NAME,CUSTOMER_ADDRESS,START_DATE,START_TIME24H,START_TIME12H,SIZE_OF_KITCHEN,INS_FINISHED_DATE,FREQ_OF_CLEANING,EXPIRY_DATE,WFTGM_CANOPY_BEFORE,COND_BEFORE_CLEAN_CNPY,IMAGE_BEFORE_CLEAN_CNPY,WFTGM_DUCT1_BEFORE,COND_BEFR_CLEAN_DUCT1,IMAGE_BEFR_CLEAN_DUCT1,WFTGM_FAN_BEFORE,COND_BEFR_CLEAN_FAN,IMAGE_BEFR_CLEAN_FAN,WFTGM_DISCHARGE_BEFORE,COND_BEFR_CLEAN_DISCHARGE,IMAGE_BEFR_CLEAN_DISCHARGE,TOTAL_BEFORE,MEAN_BEFORE,WFTGM_CANOPY_AFTER,COND_AFTER_CLEAN_CNPY,IMAGE_AFTER_CLEAN_CNPY,WFTGM_DUCT1_AFTER,COND_AFTER_CLEAN_DUCT1,IMAGE_AFTER_CLEAN_DUCT1,WFTGM_FAN_AFTER,COND_AFTER_CLEAN_FAN,IMAGE_AFTER_CLEAN_FAN,WFTGM_DISCHARGE_AFTER,COND_AFTER_CLEAN_DISCHARGE,IMAGE_AFTER_CLEAN_DISCHARGE,DESCRIPTION,IMAGE_OF_SCHEME_DIAGRAM,IMAGE_OF_WORK
