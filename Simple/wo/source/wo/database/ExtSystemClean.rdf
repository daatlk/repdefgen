-------------------- PACKAGE IMPLEMENTATION ---------------------------------
-----------------------------------------------------------------------------

PROMPT Creating EXT_SYSTEM_CLEAN_RPI implementation

CREATE OR REPLACE PACKAGE BODY EXT_SYSTEM_CLEAN_RPI IS

   TYPE binds$ IS RECORD (
      wo_no                     NUMBER,
      task_no                   NUMBER,
      task_seq                  VARCHAR2(32000));

   CURSOR get_ext_system_clean_header (task_seq_ VARCHAR2, wo_no_ VARCHAR2) IS
      SELECT
         jt.task_seq,
         jt.wo_no,
         jt.customer_no,
         customer_info_api.get_name(jt.customer_no) AS customer_name,
         csa.address AS customer_address,
         TO_CHAR(jt.actual_start, 'DD/MM/YYYY') AS start_date,
         TO_CHAR(jt.actual_start, 'HH24:MI:SS') AS start_time24h,
         TO_CHAR(jt.actual_start, 'HH:MI:SS AM') AS start_time12h,
         MAX(
            CASE
               WHEN s.survey_id = 'BEFORE_CLEAN_SURVEY'
               AND survey_question_api.get_question_no(s.survey_id, s.question_id) = '2'
               THEN survey_alt_item_api.get_item_description(s.alternative_id, s.answer)
            END
            ) AS size_of_kitchen,
         
         MAX(
            CASE
               WHEN s.survey_id = 'COMPLETE EXTRACTION'
               AND survey_question_api.get_question_no(s.survey_id, s.question_id) = '6'
               THEN s.answer
            END
            ) AS ins_finished_date,
         
         MAX(
            CASE
               WHEN s.survey_id = 'COMPLETE EXTRACTION'
               AND survey_question_api.get_question_no(s.survey_id, s.question_id) = '4'
               THEN s.answer
            END
            ) AS freq_of_cleaning,
         
         MAX(
            CASE
               WHEN s.survey_id = 'COMPLETE EXTRACTION'
               AND survey_question_api.get_question_no(s.survey_id, s.question_id) = '7'
               THEN s.answer
            END
            ) AS expiry_date
            
      FROM jt_task_light_uiv jt
      
      LEFT JOIN (
         SELECT a.customer_id, a.address
         FROM customer_info_address a
         JOIN customer_info_address_type t
         ON a.customer_id = t.customer_id
         AND a.address_id  = t.address_id
         WHERE t.def_address = 'TRUE'
         AND t.address_type_code = 'Delivery'
         ) csa
         ON csa.customer_id = jt.customer_no
         
         LEFT JOIN jt_task_survey_answers s
         ON s.task_seq = jt.task_seq
         AND s.answer_set = (
            SELECT MAX(s2.answer_set)
            FROM jt_task_survey_answers s2
            WHERE s2.survey_id = s.survey_id
            AND s2.task_seq  = s.task_seq
            )
         
            WHERE jt.task_seq = task_seq_
            AND jt.wo_no   = wo_no_
            
            GROUP BY
            jt.task_seq,
                   jt.wo_no,
                   jt.customer_no,
                   jt.actual_start,
                   csa.address;

   CURSOR get_ext_system_clean_details (task_seq_ VARCHAR2, wo_no_ VARCHAR2) IS
      SELECT
      
      /* ================= BEFORE SURVEY================= */
      
       MAX(CASE
             WHEN b.question_no = 4 THEN
              b.answer
           END) AS wftgm_canopy_before,
       MAX(CASE
             WHEN b.question_no = 5 THEN
              survey_alt_item_api.Get_Item_Description(b.alternative_id, b.answer)
           END) AS cond_before_clean_cnpy,
       MAX(CASE
             WHEN b.q3_answer = 1 THEN
              med_b.item_id
           END) AS image_before_clean_cnpy,
       
       MAX(CASE
             WHEN b.question_no = 7 THEN
              b.answer
           END) AS wftgm_duct1_before,
       MAX(CASE
             WHEN b.question_no = 8 THEN
              survey_alt_item_api.Get_Item_Description(b.alternative_id, b.answer)
           END) AS cond_befr_clean_duct1,
       MAX(CASE
             WHEN b.q3_answer = 2 THEN
              med_b.item_id
           END) AS image_befr_clean_duct1,
       
       MAX(CASE
             WHEN b.question_no = 10 THEN
              b.answer
           END) AS wftgm_fan_before,
       MAX(CASE
             WHEN b.question_no = 11 THEN
              survey_alt_item_api.Get_Item_Description(b.alternative_id, b.answer)
           END) AS cond_befr_clean_fan,
       MAX(CASE
             WHEN b.q3_answer = 3 THEN
              med_b.item_id
           END) AS image_befr_clean_fan,
       
       MAX(CASE
             WHEN b.question_no = 13 THEN
              b.answer
           END) AS wftgm_discharge_before,
       MAX(CASE
             WHEN b.question_no = 14 THEN
              survey_alt_item_api.Get_Item_Description(b.alternative_id, b.answer)
           END) AS cond_befr_clean_discharge,
       MAX(CASE
             WHEN b.q3_answer = 4 THEN
              med_b.item_id
           END) AS image_befr_clean_discharge,
       
       (NVL(MAX(CASE
                  WHEN b.question_no = 4 THEN
                   TO_NUMBER(b.answer)
                END),
            0) + NVL(MAX(CASE
                            WHEN b.question_no = 7 THEN
                             TO_NUMBER(b.answer)
                          END),
                      0) + NVL(MAX(CASE
                                      WHEN b.question_no = 10 THEN
                                       TO_NUMBER(b.answer)
                                    END),
                                0) + NVL(MAX(CASE
                                                WHEN b.question_no = 13 THEN
                                                 TO_NUMBER(b.answer)
                                              END),
                                          0)) AS total_before,
       
       (NVL(MAX(CASE
                  WHEN b.question_no = 4 THEN
                   TO_NUMBER(b.answer)
                END),
            0) + NVL(MAX(CASE
                            WHEN b.question_no = 7 THEN
                             TO_NUMBER(b.answer)
                          END),
                      0) + NVL(MAX(CASE
                                      WHEN b.question_no = 10 THEN
                                       TO_NUMBER(b.answer)
                                    END),
                                0) + NVL(MAX(CASE
                                                WHEN b.question_no = 13 THEN
                                                 TO_NUMBER(b.answer)
                                              END),
                                          0)) / 4 AS mean_before,
       
       /* ================= AFTER SURVEY================= */
       
       MAX(CASE
             WHEN a.question_no = 2 THEN
              a.answer
           END) AS wftgm_canopy_after,
       MAX(CASE
             WHEN a.question_no = 4 THEN
              survey_alt_item_api.Get_Item_Description(a.alternative_id, a.answer)
           END) AS cond_after_clean_cnpy,
       MAX(CASE
             WHEN a.q3_answer = 1 THEN
              med_a.item_id
           END) AS image_after_clean_cnpy,
       
       MAX(CASE
             WHEN a.question_no = 6 THEN
              a.answer
           END) AS wftgm_duct1_after,
       MAX(CASE
             WHEN a.question_no = 7 THEN
              survey_alt_item_api.Get_Item_Description(a.alternative_id, a.answer)
           END) AS cond_after_clean_duct1,
       MAX(CASE
             WHEN a.q3_answer = 2 THEN
              med_a.item_id
           END) AS image_after_clean_duct1,
       
       MAX(CASE
             WHEN a.question_no = 9 THEN
              a.answer
           END) AS wftgm_fan_after,
       MAX(CASE
             WHEN a.question_no = 10 THEN
              survey_alt_item_api.Get_Item_Description(a.alternative_id, a.answer)
           END) AS cond_after_clean_fan,
       MAX(CASE
             WHEN a.q3_answer = 3 THEN
              med_a.item_id
           END) AS image_after_clean_fan,
       
       MAX(CASE
             WHEN a.question_no = 12 THEN
              a.answer
           END) AS wftgm_discharge_after,
       MAX(CASE
             WHEN a.question_no = 13 THEN
              survey_alt_item_api.Get_Item_Description(a.alternative_id, a.answer)
           END) AS cond_after_clean_discharge,
       MAX(CASE
             WHEN a.q3_answer = 4 THEN
              med_a.item_id
           END) AS image_after_clean_discharge,
       
       /* ================= COMPLETE EXTRACTION SURVEY ================= */
       
       MAX(CASE
             WHEN c.question_no = 2 THEN
              c.answer
           END) AS description,
       MAX(med_c.sd_item_id) AS image_of_scheme_diagram,
       MAX(med_c.wc_item_id) AS image_of_work
      
        FROM dual
      
      /* ================= BEFORE SURVEY ================= */
        left join (SELECT j.task_seq,
                          j.wo_no,
                          survey_question_api.get_question_no(j.survey_id,
                                                              j.question_id) question_no,
                          latest.q3_answer,
                          latest.latest_answer_set,
                          j.answer,
                          j.answer_id,
                          j.alternative_id
                     FROM jt_task_survey_answers j
                     JOIN (SELECT jt.answer q3_answer,
                                 MAX(jt.answer_set) latest_answer_set
                            FROM jt_task_survey_answers jt
                           WHERE jt.task_seq = task_seq_
                             AND jt.survey_id = 'BEFORE_CLEAN_SURVEY'
                             AND survey_question_api.get_question_no(jt.survey_id,
                                                                     jt.question_id) = 3
                           GROUP BY jt.answer) latest
                       ON j.answer_set = latest.latest_answer_set
                      AND j.survey_id = 'BEFORE_CLEAN_SURVEY'
                      AND j.task_seq = task_seq_
                      AND j.wo_no = wo_no_) b
          ON 1 = 1
      
      /* BEFORE CAPTURE IMAGES */
        LEFT JOIN jt_task_survey_answers cib
          ON cib.main_answer_set = b.latest_answer_set
         AND cib.task_seq = b.task_seq
         AND cib.survey_id = 'CAPTURE_IMAGES'
         AND cib.root_survey_id = 'BEFORE_CLEAN_SURVEY'
      
      /* BEFORE MEDIA */
        LEFT JOIN (SELECT ml.connected_obj_ref1 AS answer_id,
                          MAX(mj.item_id) item_id
                     FROM MEDIA_LIBRARY_ITEM_JOIN mj
                     JOIN MEDIA_LIBRARY ml
                       ON ml.library_id = mj.library_id
                    GROUP BY ml.connected_obj_ref1) med_b
          ON med_b.answer_id = cib.answer_id
      
      /* ================= AFTER SURVEY ================= */
        LEFT JOIN (SELECT j.task_seq,
                          j.wo_no,
                          survey_question_api.get_question_no(j.survey_id,
                                                              j.question_id) question_no,
                          latest.q3_answer,
                          latest.latest_answer_set,
                          j.answer,
                          j.answer_id,
                          j.alternative_id
                     FROM jt_task_survey_answers j
                     JOIN (SELECT jt.answer q3_answer,
                                 MAX(jt.answer_set) latest_answer_set
                            FROM jt_task_survey_answers jt
                           WHERE jt.task_seq = task_seq_
                             AND jt.survey_id = 'AFTER_CLEAN_SURVEY'
                             AND survey_question_api.get_question_no(jt.survey_id,
                                                                     jt.question_id) = 2
                           GROUP BY jt.answer) latest
                       ON j.answer_set = latest.latest_answer_set
                      AND j.survey_id = 'AFTER_CLEAN_SURVEY'
                      AND j.task_seq = task_seq_
                      AND j.wo_no = wo_no_) a
          ON 1 = 1
      
      /* AFTER CAPTURE IMAGES */
        LEFT JOIN jt_task_survey_answers ci_a
          ON ci_a.main_answer_set = a.latest_answer_set
         AND ci_a.task_seq = a.task_seq
         AND ci_a.survey_id = 'CAPTURE_IMAGES'
         AND ci_a.root_survey_id = 'AFTER_CLEAN_SURVEY'
      
      /* AFTER MEDIA */
        LEFT JOIN (SELECT ml.connected_obj_ref1 AS answer_id,
                          MAX(mj.item_id) item_id
                     FROM MEDIA_LIBRARY_ITEM_JOIN mj
                     JOIN MEDIA_LIBRARY ml
                       ON ml.library_id = mj.library_id
                    GROUP BY ml.connected_obj_ref1) med_a
          ON med_a.answer_id = ci_a.answer_id
      
      /* ================= COMPLETE EXTRACTION SURVEY ================= */
        left join (SELECT s.task_seq,
                          s.wo_no,
                          survey_question_api.get_question_no(s.survey_id,
                                                              s.question_id) question_no,
                          s.answer_set,
                          s.answer,
                          s.answer_id,
                          s.alternative_id
                     FROM jt_task_survey_answers s
                    WHERE s.task_seq = task_seq_
                      AND s.wo_no = wo_no_
                      AND S.survey_id = 'COMPLETE EXTRACTION'
                      AND s.answer_set =
                          (SELECT MAX(s2.answer_set)
                             FROM jt_task_survey_answers s2
                            WHERE s2.survey_id = s.survey_id
                              AND s2.task_seq = s.task_seq)) c
          ON 1 = 1
      
      /* COMPLETE EXTRACTION SURVEY MEDIA */
        LEFT JOIN (SELECT s.task_seq,
                          s.wo_no,
                          s.answer_set,
                          MAX(s.answer_id) AS answer_id,
                          MAX(mj.item_id) AS sd_item_id,
                          MIN(mj.item_id) AS wc_item_id
                     FROM jt_task_survey_answers s
                     join media_library ml
                       ON ml.connected_obj_ref1 = s.answer_id
                     JOIN media_library_item_join mj
                       ON ml.library_id = mj.library_id
                    WHERE s.task_seq = task_seq_
                      AND s.wo_no = wo_no_
                      AND s.survey_id = 'CAPTURE_IMAGES'
                      AND s.root_survey_id = 'COMPLETE EXTRACTION'
                      AND s.main_answer_set =
                          (SELECT MAX(s2.answer_set)
                             FROM jt_task_survey_answers s2
                            WHERE s2.task_seq = task_seq_
                              AND s2.survey_id = 'COMPLETE EXTRACTION')
                    GROUP BY s.task_seq, s.wo_no, s.answer_set) med_c
          ON 1 = 1;

