--@IgnoreWrongParamOrder
PROCEDURE Add_Result_Row___ (
   result_key$_               IN NUMBER,
   binds$_                    IN binds$,
   rec_ext_system_clean_header_ IN get_ext_system_clean_header%ROWTYPE DEFAULT NULL,
   rec_ext_system_clean_details_ IN get_ext_system_clean_details%ROWTYPE DEFAULT NULL,
   row_no$_                   IN OUT NUMBER)
IS
BEGIN
   INSERT INTO EXT_SYSTEM_CLEAN_RPT (
      result_key,
      wo_no,
      task_no,
      task_seq,
      customer_no,
      customer_name,
      customer_address,
      start_date,
      start_time24h,
      start_time12h,
      size_of_kitchen,
      ins_finished_date,
      freq_of_cleaning,
      expiry_date,
      wftgm_canopy_before,
      cond_before_clean_cnpy,
      image_before_clean_cnpy,
      wftgm_duct1_before,
      cond_befr_clean_duct1,
      image_befr_clean_duct1,
      wftgm_fan_before,
      cond_befr_clean_fan,
      image_befr_clean_fan,
      wftgm_discharge_before,
      cond_befr_clean_discharge,
      image_befr_clean_discharge,
      total_before,
      mean_before,
      wftgm_canopy_after,
      cond_after_clean_cnpy,
      image_after_clean_cnpy,
      wftgm_duct1_after,
      cond_after_clean_duct1,
      image_after_clean_duct1,
      wftgm_fan_after,
      cond_after_clean_fan,
      image_after_clean_fan,
      wftgm_discharge_after,
      cond_after_clean_discharge,
      image_after_clean_discharge,
      description,
      image_of_scheme_diagram,
      image_of_work,
      row_no, parent_row_no)
   VALUES (
      result_key$_,
      nvl(rec_ext_system_clean_header_.wo_no,
      binds$_.wo_no),
      binds$_.task_no,
      rec_ext_system_clean_header_.task_seq,
      rec_ext_system_clean_header_.customer_no,
      rec_ext_system_clean_header_.customer_name,
      rec_ext_system_clean_header_.customer_address,
      rec_ext_system_clean_header_.start_date,
      rec_ext_system_clean_header_.start_time24h,
      rec_ext_system_clean_header_.start_time12h,
      rec_ext_system_clean_header_.size_of_kitchen,
      rec_ext_system_clean_header_.ins_finished_date,
      rec_ext_system_clean_header_.freq_of_cleaning,
      rec_ext_system_clean_header_.expiry_date,
      rec_ext_system_clean_details_.wftgm_canopy_before,
      rec_ext_system_clean_details_.cond_before_clean_cnpy,
      rec_ext_system_clean_details_.image_before_clean_cnpy,
      rec_ext_system_clean_details_.wftgm_duct1_before,
      rec_ext_system_clean_details_.cond_befr_clean_duct1,
      rec_ext_system_clean_details_.image_befr_clean_duct1,
      rec_ext_system_clean_details_.wftgm_fan_before,
      rec_ext_system_clean_details_.cond_befr_clean_fan,
      rec_ext_system_clean_details_.image_befr_clean_fan,
      rec_ext_system_clean_details_.wftgm_discharge_before,
      rec_ext_system_clean_details_.cond_befr_clean_discharge,
      rec_ext_system_clean_details_.image_befr_clean_discharge,
      rec_ext_system_clean_details_.total_before,
      rec_ext_system_clean_details_.mean_before,
      rec_ext_system_clean_details_.wftgm_canopy_after,
      rec_ext_system_clean_details_.cond_after_clean_cnpy,
      rec_ext_system_clean_details_.image_after_clean_cnpy,
      rec_ext_system_clean_details_.wftgm_duct1_after,
      rec_ext_system_clean_details_.cond_after_clean_duct1,
      rec_ext_system_clean_details_.image_after_clean_duct1,
      rec_ext_system_clean_details_.wftgm_fan_after,
      rec_ext_system_clean_details_.cond_after_clean_fan,
      rec_ext_system_clean_details_.image_after_clean_fan,
      rec_ext_system_clean_details_.wftgm_discharge_after,
      rec_ext_system_clean_details_.cond_after_clean_discharge,
      rec_ext_system_clean_details_.image_after_clean_discharge,
      rec_ext_system_clean_details_.description,
      rec_ext_system_clean_details_.image_of_scheme_diagram,
      rec_ext_system_clean_details_.image_of_work,
      row_no$_, 0);
   row_no$_ := row_no$_+1;
END Add_Result_Row___;

-----------------------------------------------------------------------------
-------------------- REPORT EXECUTION ---------------------------------------
-----------------------------------------------------------------------------

PROCEDURE Execute_Report (
   report_attr_    IN VARCHAR2,
   parameter_attr_ IN VARCHAR2 )
IS
   result_key$_              NUMBER;
   row_no$_                  NUMBER := 1;
   binds$_                   binds$;
   xml$_                     CLOB;
   outer_filter_attr$_       VARCHAR2(32000);
   outer_filter_where$_      VARCHAR2(32000);
   inner_filter_attr$_       VARCHAR2(32000);
   inner_filter_where$_      VARCHAR2(32000);
   has_ext_system_clean_header_ BOOLEAN;
   rec_ext_system_clean_header_ get_ext_system_clean_header%ROWTYPE;
   par_ext_system_clean_header_ binds$;
   has_ext_system_clean_details_ BOOLEAN;
   rec_ext_system_clean_details_ get_ext_system_clean_details%ROWTYPE;
   par_ext_system_clean_details_ binds$;
BEGIN
   General_SYS.Init_Method(lu_name_, 'EXT_SYSTEM_CLEAN_RPI', 'Execute_Report');
   result_key$_                 := Client_SYS.Attr_Value_To_Number(Client_SYS.Get_Item_Value('RESULT_KEY', report_attr_));
   binds$_.wo_no                := Client_SYS.Attr_Value_To_Number(Client_SYS.Get_Item_Value('WO_NO', parameter_attr_));
   binds$_.task_no              := Client_SYS.Attr_Value_To_Number(Client_SYS.Get_Item_Value('TASK_NO', parameter_attr_));

   Xml_Record_Writer_SYS.Create_Report_Header(xml$_, 'EXT_SYSTEM_CLEAN_REP', 'Extraction System Cleaning');

   has_ext_system_clean_header_ := FALSE;
   par_ext_system_clean_header_ := binds$_;
   Xml_Record_Writer_SYS.Start_Element(xml$_, 'HEADERS1');
   OPEN get_ext_system_clean_header(binds$_.task_no, binds$_.wo_no);
   LOOP
      FETCH get_ext_system_clean_header INTO rec_ext_system_clean_header_;
      has_ext_system_clean_header_ := get_ext_system_clean_header%FOUND OR get_ext_system_clean_header%ROWCOUNT > 0;
      EXIT WHEN get_ext_system_clean_header%NOTFOUND;
      Xml_Record_Writer_SYS.Start_Element(xml$_, 'EXT_SYSTEM_CLEAN_HEADER');
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'TASK_SEQ', rec_ext_system_clean_header_.task_seq);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'WO_NO', rec_ext_system_clean_header_.wo_no);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CUSTOMER_NO', rec_ext_system_clean_header_.customer_no);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CUSTOMER_NAME', rec_ext_system_clean_header_.customer_name);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'CUSTOMER_ADDRESS', rec_ext_system_clean_header_.customer_address);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'START_DATE', rec_ext_system_clean_header_.start_date);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'START_TIME24H', rec_ext_system_clean_header_.start_time24h);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'START_TIME12H', rec_ext_system_clean_header_.start_time12h);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'SIZE_OF_KITCHEN', rec_ext_system_clean_header_.size_of_kitchen);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'INS_FINISHED_DATE', rec_ext_system_clean_header_.ins_finished_date);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'FREQ_OF_CLEANING', rec_ext_system_clean_header_.freq_of_cleaning);
      Xml_Record_Writer_SYS.Add_Element(xml$_, 'EXPIRY_DATE', rec_ext_system_clean_header_.expiry_date);
      has_ext_system_clean_details_ := FALSE;
      par_ext_system_clean_details_ := binds$_;
      binds$_.wo_no := rec_ext_system_clean_header_.wo_no;
      Xml_Record_Writer_SYS.Start_Element(xml$_, 'EXT_DETAILS');
      OPEN get_ext_system_clean_details(binds$_.task_no, rec_ext_system_clean_header_.wo_no);
      LOOP
         FETCH get_ext_system_clean_details INTO rec_ext_system_clean_details_;
         has_ext_system_clean_details_ := get_ext_system_clean_details%FOUND OR get_ext_system_clean_details%ROWCOUNT > 0;
         EXIT WHEN get_ext_system_clean_details%NOTFOUND;
         Xml_Record_Writer_SYS.Start_Element(xml$_, 'EXT_SYSTEM_CLEAN_DETAILS');
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_CANOPY_BEFORE', rec_ext_system_clean_details_.wftgm_canopy_before);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_BEFORE_CLEAN_CNPY', rec_ext_system_clean_details_.cond_before_clean_cnpy);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_BEFORE_CLEAN_CNPY', rec_ext_system_clean_details_.image_before_clean_cnpy);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_DUCT1_BEFORE', rec_ext_system_clean_details_.wftgm_duct1_before);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_BEFR_CLEAN_DUCT1', rec_ext_system_clean_details_.cond_befr_clean_duct1);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_BEFR_CLEAN_DUCT1', rec_ext_system_clean_details_.image_befr_clean_duct1);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_FAN_BEFORE', rec_ext_system_clean_details_.wftgm_fan_before);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_BEFR_CLEAN_FAN', rec_ext_system_clean_details_.cond_befr_clean_fan);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_BEFR_CLEAN_FAN', rec_ext_system_clean_details_.image_befr_clean_fan);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_DISCHARGE_BEFORE', rec_ext_system_clean_details_.wftgm_discharge_before);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_BEFR_CLEAN_DISCHARGE', rec_ext_system_clean_details_.cond_befr_clean_discharge);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_BEFR_CLEAN_DISCHARGE', rec_ext_system_clean_details_.image_befr_clean_discharge);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'TOTAL_BEFORE', rec_ext_system_clean_details_.total_before);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'MEAN_BEFORE', rec_ext_system_clean_details_.mean_before);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_CANOPY_AFTER', rec_ext_system_clean_details_.wftgm_canopy_after);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_AFTER_CLEAN_CNPY', rec_ext_system_clean_details_.cond_after_clean_cnpy);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_AFTER_CLEAN_CNPY', rec_ext_system_clean_details_.image_after_clean_cnpy);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_DUCT1_AFTER', rec_ext_system_clean_details_.wftgm_duct1_after);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_AFTER_CLEAN_DUCT1', rec_ext_system_clean_details_.cond_after_clean_duct1);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_AFTER_CLEAN_DUCT1', rec_ext_system_clean_details_.image_after_clean_duct1);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_FAN_AFTER', rec_ext_system_clean_details_.wftgm_fan_after);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_AFTER_CLEAN_FAN', rec_ext_system_clean_details_.cond_after_clean_fan);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_AFTER_CLEAN_FAN', rec_ext_system_clean_details_.image_after_clean_fan);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'WFTGM_DISCHARGE_AFTER', rec_ext_system_clean_details_.wftgm_discharge_after);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'COND_AFTER_CLEAN_DISCHARGE', rec_ext_system_clean_details_.cond_after_clean_discharge);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_AFTER_CLEAN_DISCHARGE', rec_ext_system_clean_details_.image_after_clean_discharge);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'DESCRIPTION', rec_ext_system_clean_details_.description);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_OF_SCHEME_DIAGRAM', rec_ext_system_clean_details_.image_of_scheme_diagram);
         Xml_Record_Writer_SYS.Add_Element(xml$_, 'IMAGE_OF_WORK', rec_ext_system_clean_details_.image_of_work);
         Xml_Record_Writer_SYS.End_Element(xml$_, 'EXT_SYSTEM_CLEAN_DETAILS');
         Add_Result_Row___(result_key$_,
                           binds$_ => binds$_,
                           rec_ext_system_clean_header_ => rec_ext_system_clean_header_,
                           rec_ext_system_clean_details_ => rec_ext_system_clean_details_,
                           row_no$_ => row_no$_);
      END LOOP;
      CLOSE get_ext_system_clean_details;
      Xml_Record_Writer_SYS.End_Element(xml$_, 'EXT_DETAILS');
      binds$_ := par_ext_system_clean_details_;
      IF NOT has_ext_system_clean_details_ THEN
         Add_Result_Row___(result_key$_,
                           binds$_ => binds$_,
                           rec_ext_system_clean_header_ => rec_ext_system_clean_header_,
                           row_no$_ => row_no$_);
      END IF;

      Xml_Record_Writer_SYS.End_Element(xml$_, 'EXT_SYSTEM_CLEAN_HEADER');
   END LOOP;
   CLOSE get_ext_system_clean_header;
   Xml_Record_Writer_SYS.End_Element(xml$_, 'HEADERS1');
   binds$_ := par_ext_system_clean_header_;
   IF NOT has_ext_system_clean_header_ THEN
      Add_Result_Row___(result_key$_,
                        binds$_ => binds$_,
                        row_no$_ => row_no$_);
   END IF;

   Xml_Record_Writer_SYS.End_Element(xml$_, 'EXT_SYSTEM_CLEAN_REP');
   Report_SYS.Finish_Xml_Report('EXT_SYSTEM_CLEAN_REP', result_key$_, xml$_);
   EXCEPTION
      WHEN OTHERS THEN
         IF get_ext_system_clean_header%ISOPEN THEN
            CLOSE get_ext_system_clean_header;
         END IF;
         IF get_ext_system_clean_details%ISOPEN THEN
            CLOSE get_ext_system_clean_details;
         END IF;
         RAISE;
END Execute_Report;

